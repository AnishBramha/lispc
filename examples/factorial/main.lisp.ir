FUNC _fact
PARAM @16 0
%t1 = LESS_EQUAL @16 0
JMPF %t1 L_else_0
%t0 = 1
JMP L_endif0
LABEL L_else_0
%t2 = SUB @16 1
ARG 0 %t2
%t3 = CALL _fact 1
%t4 = MUL @16 %t3
%t0 = %t4
LABEL L_endif0
RET %t0
END _fact

ARG 0 0
%t0 = CALL _fact 1
PRINT %t0
PRINT "\n"

ARG 0 6
%t0 = CALL _fact 1
PRINT %t0
PRINT "\n"

