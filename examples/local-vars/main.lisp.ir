x = 1

@16 = 1
%t0 = ADD x @16
PRINT %t0
PRINT "\n"

@16 = 100
@32 = 2
%t0 = ADD @16 @32
PRINT %t0
NEWLINE

@16 = 3
@32 = 4
PRINT "a^2 + b^2 = "
%t0 = POW @16 2
PRINT %t0
PRINT " + "
%t1 = POW @32 2
PRINT %t1
PRINT " = "
%t2 = POW @16 2
%t3 = POW @32 2
%t4 = ADD %t2 %t3
PRINT %t4

NEWLINE

@16 = "Hello"
PRINT @16
PRINT ", World!\n"
NEWLINE

